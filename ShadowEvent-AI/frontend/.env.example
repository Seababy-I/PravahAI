# ─── PravahAI Frontend — Environment Template ──────────────────────────────────
#
# Copy this file to `.env` and fill in values for your environment.
#   cp .env.example .env
#
# This file IS safe to commit — it contains no secrets.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the PravahAI FastAPI backend
# Local development:
#   VITE_API_URL=http://localhost:8000
# Production (example):
#   VITE_API_URL=https://api.pravah.ai
VITE_API_URL=http://localhost:8000
