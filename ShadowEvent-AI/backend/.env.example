# ShadowEvent AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── MapMyIndia (Mappls) API Key ───────────────────────────────────────────────
# Register at: https://auth.mappls.com/console/
# Navigate to: Dashboard → My Projects → Your Project → REST API Key
# Once set, the system will automatically:
#   1. Switch map tiles from CARTO Dark → MapMyIndia tiles
#   2. Enable live MapMyIndia context on the Impact Map page
#   3. Show "MapMyIndia Active" badge in the UI
#
# URL format used internally:
#   Tiles:      https://tiles.mappls.com/advancedmaps/v1/{KEY}/map_tiles/{z}/{x}/{y}.png
#   Static map: https://apis.mappls.com/advancedmaps/v1/{KEY}/still_image?center=...

MMI_REST_KEY=PASTE_YOUR_REST_KEY_HERE

# ─── Gemini API Key (Phase 7 Agent Intelligence Layer) ─────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Used by: POST /agent/corridor-advisory, /agent/planned-event-advisory, /agent/zone-brief
# If not set, the system falls back to rule-based advisories (no AI generation).
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# ─── Optional: Python UTF-8 mode ───────────────────────────────────────────────
PYTHONUTF8=1
